.container { display: flex; flex-direction: column; min-height: 100vh; background: #f8fafc; }
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 32rpx; background: #fff; border-bottom: 1rpx solid #e2e8f0;
}
.header-btn {
  font-size: 22rpx; padding: 8rpx 18rpx; background: #fef2f2; color: #dc2626;
  border: 1rpx solid #fecaca; border-radius: 9999rpx; margin: 0; line-height: 1.6;
}
.header-btn::after { border: none; }

.list { flex: 1; padding: 16rpx 24rpx; }

.sess-item {
  display: flex; align-items: center; gap: 16rpx;
  background: #fff; border: 1rpx solid #e2e8f0; border-radius: 16rpx;
  padding: 24rpx 24rpx; margin-bottom: 12rpx;
}
.sess-dot {
  width: 12rpx; height: 12rpx; border-radius: 9999rpx; flex-shrink: 0;
}
.del-btn {
  font-size: 20rpx; padding: 6rpx 16rpx; background: #fff; color: #dc2626;
  border: 1rpx solid #fecaca; border-radius: 8rpx; margin: 0; line-height: 1.6;
}
.del-btn::after { border: none; }

.empty-state {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 80rpx 32rpx;
}
.empty-icon { font-size: 96rpx; margin-bottom: 16rpx; }
.primary-btn {
  background: linear-gradient(135deg, #3b82f6, #6366f1); color: #fff;
  font-size: 26rpx; padding: 16rpx 48rpx; border-radius: 9999rpx;
  border: none; line-height: 1.6;
}
.primary-btn::after { border: none; }

.flex-1 { flex: 1; min-width: 0; }
.text-sm { font-size: 26rpx; }
.text-md { font-size: 30rpx; }
.text-xs { font-size: 22rpx; }
.font-semibold { font-weight: 600; }
.text-slate-400 { color: #94a3b8; }
.text-slate-500 { color: #64748b; }
.text-slate-600 { color: #475569; }
.text-slate-900 { color: #0f172a; }
