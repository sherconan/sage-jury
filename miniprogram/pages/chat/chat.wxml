<view class="container">
  <!-- TOP: sage 选择 + sessions 入口 -->
  <view class="header">
    <view class="header-left" bindtap="onSagePickerToggle">
      <view class="sage-avatar" style="background:{{activeSage.color}}">{{activeSage.initials}}</view>
      <view class="header-text">
        <view class="header-title">{{activeSession.title || ('和 ' + activeSage.display + ' 对话')}}</view>
        <view class="header-sub">{{activeSage.philosophy}}</view>
      </view>
      <view class="header-arrow">{{sagePickerOpen ? '▲' : '▼'}}</view>
    </view>
    <view class="header-right">
      <button class="header-btn" bindtap="onNewSession" hover-class="hover">+ 新</button>
      <button class="header-btn" bindtap="onGoSessions" hover-class="hover">历史</button>
    </view>
  </view>

  <!-- Sage picker dropdown -->
  <view wx:if="{{sagePickerOpen}}" class="sage-picker">
    <view wx:for="{{sages}}" wx:key="slug" class="sage-pick-item {{item.slug === activeSage.slug ? 'active' : ''}}"
      data-slug="{{item.slug}}" bindtap="onSelectSage">
      <view class="sage-avatar" style="background:{{item.color}}">{{item.initials}}</view>
      <view class="flex-1">
        <view class="text-sm font-semibold">{{item.display}}</view>
        <view class="text-xs text-slate-500">{{item.philosophy}}</view>
      </view>
      <view wx:if="{{item.slug === activeSage.slug}}" class="text-xs text-blue-600">✓</view>
    </view>
  </view>

  <!-- Messages 区域 -->
  <scroll-view class="messages" scroll-y scroll-into-view="{{scrollTo}}" enhanced show-scrollbar="{{false}}">
    <view wx:if="{{messages.length === 0}}" class="empty">
      <view class="empty-avatar" style="background:{{activeSage.color}}">{{activeSage.initials}}</view>
      <view class="empty-title">和 {{activeSage.display}} 对话</view>
      <view class="empty-subtitle">{{activeSage.philosophy}}</view>
      <view class="empty-meta">基于 {{activeSage.total_posts}} 条真实雪球发言 · 4 工具 (语义搜/网搜/实时行情/K线)</view>

      <!-- ⭐ 4 sage 横排选择器（一眼可见可切换）-->
      <view class="sage-row-label">切换大佬</view>
      <view class="sage-row">
        <view wx:for="{{sages}}" wx:key="slug" class="sage-row-card {{item.slug === activeSage.slug ? 'active' : ''}}"
          data-slug="{{item.slug}}" bindtap="onSelectSage">
          <view class="sage-row-avatar" style="background:{{item.color}}">{{item.initials}}</view>
          <view class="sage-row-name">{{item.display}}</view>
        </view>
      </view>

      <view class="starters">
        <view wx:for="{{starters}}" wx:key="*this" class="starter-chip" data-q="{{item}}" bindtap="onStarter">{{item}}</view>
      </view>
    </view>

    <view wx:for="{{messages}}" wx:key="ts" id="m{{index}}" class="msg-row {{item.role === 'user' ? 'msg-user' : 'msg-sage'}}">
      <view class="msg-avatar {{item.role === 'user' ? 'avatar-user' : ''}}" style="{{item.role === 'sage' ? ('background:' + activeSage.color) : ''}}">
        {{item.role === 'user' ? '你' : activeSage.initials}}
      </view>
      <view class="msg-bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-sage'}}">
        <!-- v60.1: Analyst 内心分析卡（紫色，默认展开，writer 开始后自动折叠） -->
        <view wx:if="{{item.role === 'sage' && item.analystThinking}}" class="analyst-card">
          <view class="analyst-summary" data-mi="{{index}}" bindtap="onToggleAnalyst" hover-class="analyst-summary-hover">
            <text class="analyst-emoji">💭</text>
            <text class="analyst-title">{{item.analystDone ? '内心分析' : (item.writerStarted ? '已分析完，落笔中' : '内心分析中…')}}</text>
            <text wx:if="{{!item.analystDone}}" class="analyst-spin">⟳</text>
            <text wx:if="{{item.analystDone}}" class="analyst-check">✓</text>
            <text class="analyst-arrow {{item.analystOpen ? 'open' : ''}}">⌄</text>
          </view>
          <view wx:if="{{item.analystOpen}}" class="analyst-body">{{item.analystThinking}}</view>
        </view>

        <!-- v58: tool calls 折叠 pill（人话标签 + 紧凑） -->
        <view wx:if="{{item.role === 'sage' && item.toolCalls && item.toolCalls.length > 0}}" class="tools-card">
          <view class="tools-summary" data-mi="{{index}}" bindtap="onToggleTools" hover-class="tools-summary-hover">
            <text class="tools-emoji">🛠️</text>
            <text class="tools-title">用了 {{item.toolCalls.length}} 个工具</text>
            <text wx:if="{{item.toolsAllDone}}" class="tools-check">✓</text>
            <text wx:else class="tools-spin">⟳</text>
            <text class="tools-arrow {{item.toolsOpen ? 'open' : ''}}">⌄</text>
          </view>
          <view wx:if="{{item.toolsOpen}}" class="tools-list">
            <view wx:for="{{item.toolCalls}}" wx:for-item="tc" wx:key="id" class="tool-pill">
              <view class="tool-pill-head">
                <text class="tool-pill-icon">{{tc.icon}}</text>
                <text class="tool-pill-label">{{tc.label}}</text>
                <text wx:if="{{tc.argsStr}}" class="tool-pill-args">· {{tc.argsStr}}</text>
                <text wx:if="{{tc.result}}" class="tool-pill-check">✓</text>
                <text wx:else class="tool-pill-spin">⟳</text>
              </view>
              <view wx:if="{{tc.result}}" class="tool-pill-result">{{tc.resultPreview}}</view>
            </view>
          </view>
        </view>

        <!-- main content -->
        <view wx:if="{{item.loading && !item.content && !item.analystThinking}}" class="loading-text">{{activeSage.display}} 正在思考...</view>
        <view wx:elif="{{item.content}}" class="msg-content" data-idx="{{index}}" bindlongpress="onLongPressMsg">
          <!-- v54: 切段渲染 [原文 N] 为可点击 chip -->
          <block wx:if="{{item.role === 'sage' && item.contentSegments && item.contentSegments.length}}">
            <block wx:for="{{item.contentSegments}}" wx:for-item="seg" wx:key="index" wx:for-index="si">
              <text wx:if="{{seg.type === 'text'}}" class="msg-text">{{seg.text}}</text>
              <text wx:elif="{{seg.type === 'cite'}}" class="cite-chip" data-mi="{{index}}" data-n="{{seg.n}}" bindtap="onCiteTap">#{{seg.n}}</text>
            </block>
          </block>
          <text wx:else class="msg-text">{{item.content}}</text>
        </view>
        <!-- v60.4-mp: 错误态重试 -->
        <view wx:if="{{item.role === 'sage' && item.errorState}}" class="error-row">
          <text class="retry-btn" data-idx="{{index}}" bindtap="onRetry" hover-class="retry-btn-hover">↻ 重试</text>
        </view>
        <!-- followups -->
        <view wx:if="{{item.followups && item.followups.length > 0}}" class="followups">
          <view wx:for="{{item.followups}}" wx:for-item="fp" wx:key="*this" class="followup-chip" data-q="{{fp}}" bindtap="onStarter">
            <text>✨ {{fp}}</text>
          </view>
        </view>
        <!-- quotes (v57.2: 含 score badges; v54: scroll target id) -->
        <view wx:if="{{item.quotes && item.quotes.length > 0}}" class="quotes">
          <view class="quotes-label">引用 {{item.quotes.length}} 条历史原帖 · 点正文 #N 跳转</view>
          <view wx:for="{{item.quotes}}" wx:for-item="q" wx:for-index="qi" wx:key="qi"
            id="q-{{item.ts}}-{{qi+1}}"
            class="quote-item {{q.highlight ? 'quote-flash' : ''}}"
            data-url="{{q.url}}" bindlongpress="onCopyQuoteUrl">
            <view class="quote-head">
              <view class="quote-num">#{{qi+1}}</view>
              <view class="quote-meta">{{q.date}} · 👍 {{q.likes}}</view>
              <view wx:if="{{q.relLabel}}" class="badge badge-rel badge-rel-{{q.relTone}}">{{q.relLabel}}</view>
              <view wx:if="{{q.recLabel}}" class="badge badge-rec badge-rec-{{q.recTone}}">{{q.recLabel}}</view>
            </view>
            <view class="quote-text">{{q.textPreview}}</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 输入区 -->
  <view class="input-bar">
    <input class="input" placeholder="问 {{activeSage.display}}..." value="{{input}}"
      bindinput="onInputChange" confirm-type="send" bindconfirm="onSubmit" disabled="{{loading}}" />
    <button class="send-btn" style="background:{{activeSage.color}}" bindtap="onSubmit"
      disabled="{{loading || !input}}" loading="{{loading}}">
      {{loading ? '发送中' : '发送'}}
    </button>
  </view>
</view>
