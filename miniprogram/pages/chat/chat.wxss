/* chat.wxss */
page { height: 100%; }
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f8fafc;
  box-sizing: border-box;
}

/* ============ HEADER (fixed horizontal layout) ============ */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #e2e8f0;
  z-index: 10;
  min-height: 96rpx;
}
.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1 1 auto;
  min-width: 0; /* 关键: 防止 flex item 被超长中文撑爆 */
  overflow: hidden;
}
.header-text {
  flex: 1 1 auto;
  min-width: 0;
  overflow: hidden;
}
.header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: keep-all;
}
.header-sub {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.header-arrow {
  font-size: 20rpx;
  color: #94a3b8;
  margin-left: 8rpx;
  flex-shrink: 0;
}
.header-right {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0; /* 关键: 按钮不被压 */
}
.header-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  background: #f1f5f9;
  color: #475569;
  border: none;
  border-radius: 9999rpx;
  margin: 0;
  line-height: 1.6;
  flex-shrink: 0;
}
.header-btn::after { border: none; }

.sage-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: bold;
  font-size: 20rpx;
  font-family: ui-monospace, monospace;
  flex-shrink: 0;
}

.sage-picker {
  background: #fff;
  border-bottom: 1rpx solid #e2e8f0;
  padding: 12rpx 16rpx;
  z-index: 9;
}
.sage-pick-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
}
.sage-pick-item.active { background: #f1f5f9; }

.messages {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #eff6ff 100%);
}

.empty {
  text-align: center;
  padding: 80rpx 32rpx;
}
.empty-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: bold;
  font-size: 36rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,.1);
}
.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #0f172a;
  margin-top: 32rpx;
}
.empty-subtitle {
  font-size: 26rpx;
  color: #64748b;
  margin-top: 12rpx;
}
.empty-meta {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}
/* === 4 sage 横排选择器 === */
.sage-row-label {
  margin-top: 48rpx;
  font-size: 22rpx;
  color: #94a3b8;
  text-align: center;
  letter-spacing: 4rpx;
}
.sage-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}
.sage-row-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 12rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #fff;
  min-width: 120rpx;
  transition: all 0.2s;
}
.sage-row-card.active {
  border-color: #3b82f6;
  background: #eff6ff;
  box-shadow: 0 4rpx 12rpx rgba(59,130,246,0.15);
}
.sage-row-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: bold;
  font-size: 20rpx;
  font-family: ui-monospace, monospace;
}
.sage-row-name {
  font-size: 22rpx;
  color: #475569;
  margin-top: 8rpx;
}
.sage-row-card.active .sage-row-name { color: #1d4ed8; font-weight: 600; }

.starters {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 32rpx;
}
.starter-chip {
  padding: 12rpx 24rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 9999rpx;
  font-size: 24rpx;
  color: #475569;
}

.msg-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.msg-user { flex-direction: row-reverse; }

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: bold;
  font-size: 22rpx;
  flex-shrink: 0;
}
.avatar-user { background: #0f172a; }

.msg-bubble {
  max-width: 78%;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,.05);
}
.bubble-user {
  background: #0f172a;
  color: #fff;
}
.bubble-sage {
  background: #fff;
  border: 1rpx solid #e2e8f0;
  color: #1e293b;
}

/* v60.1: Analyst 内心分析卡（violet 渐变） */
.analyst-card {
  margin-bottom: 16rpx;
}
.analyst-summary {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  background: #f5f3ff;
  color: #6d28d9;
  font-size: 22rpx;
  line-height: 1.4;
}
.analyst-summary-hover { background: #ede9fe; }
.analyst-emoji { font-size: 22rpx; }
.analyst-title { font-weight: 500; }
.analyst-spin {
  font-size: 20rpx;
  color: #8b5cf6;
  animation: spin 1.2s linear infinite;
  display: inline-block;
}
.analyst-check {
  font-size: 18rpx;
  color: #059669;
  font-weight: bold;
}
.analyst-arrow {
  font-size: 22rpx;
  color: #a78bfa;
  margin-left: 4rpx;
  transition: transform 0.2s;
}
.analyst-arrow.open { transform: rotate(180deg); }
.analyst-body {
  margin-top: 12rpx;
  padding: 18rpx 22rpx;
  background: linear-gradient(135deg, #faf5ff 0%, #ede9fe 100%);
  border-left: 4rpx solid #a78bfa;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #5b21b6;
  line-height: 1.65;
  white-space: pre-wrap;
}

/* v58: tool calls 折叠 pill */
.tools-card {
  margin-bottom: 16rpx;
}
.tools-summary {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 22rpx;
  line-height: 1.4;
}
.tools-summary-hover { background: #e2e8f0; }
.tools-emoji { font-size: 22rpx; }
.tools-title { font-weight: 500; }
.tools-check {
  font-size: 18rpx;
  color: #059669;
  font-weight: bold;
}
.tools-spin {
  font-size: 20rpx;
  color: #f59e0b;
  animation: spin 1.2s linear infinite;
  display: inline-block;
}
.tools-arrow {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: 4rpx;
  transition: transform 0.2s;
}
.tools-arrow.open { transform: rotate(180deg); }
.tools-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.tool-pill {
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  font-size: 22rpx;
}
.tool-pill-head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #334155;
  flex-wrap: wrap;
}
.tool-pill-icon { font-size: 22rpx; }
.tool-pill-label { color: #1e293b; font-weight: 500; }
.tool-pill-args { color: #64748b; font-size: 20rpx; }
.tool-pill-check {
  margin-left: auto;
  font-size: 18rpx;
  color: #059669;
  font-weight: bold;
}
.tool-pill-spin {
  margin-left: auto;
  font-size: 20rpx;
  color: #f59e0b;
  animation: spin 1.2s linear infinite;
  display: inline-block;
}
.tool-pill-result {
  margin-top: 8rpx;
  margin-left: 30rpx;
  padding: 10rpx 14rpx;
  background: #f1f5f9;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #475569;
  line-height: 1.6;
  max-height: 240rpx;
  overflow: hidden;
  white-space: pre-wrap;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.loading-text { color: #94a3b8; font-size: 26rpx; }
.msg-content { white-space: pre-wrap; }

.followups {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}
.followup-chip {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  color: #1d4ed8;
  padding: 8rpx 18rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
}

.quotes {
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e2e8f0;
}
.quotes-label {
  font-size: 20rpx;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 12rpx;
}
.quote-item {
  background: #f0f9ff;
  border: 1rpx solid #bae6fd;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 8rpx;
  font-size: 22rpx;
}
.quote-meta {
  color: #0369a1;
  font-size: 20rpx;
  font-family: ui-monospace, monospace;
}
.quote-text {
  color: #475569;
  margin-top: 4rpx;
  line-height: 1.5;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx 32rpx;
  background: #fff;
  border-top: 1rpx solid #e2e8f0;
}
.input {
  flex: 1;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 9999rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  color: #0f172a;
}
.send-btn {
  border-radius: 9999rpx;
  padding: 0 32rpx;
  height: 70rpx;
  line-height: 70rpx;
  color: white;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  margin: 0;
}
.send-btn::after { border: none; }
.send-btn[disabled] { opacity: 0.4; }
