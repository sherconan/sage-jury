/* chat.wxss */
page { height: 100%; }
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f8fafc;
  box-sizing: border-box;
}

/* ============ HEADER (fixed horizontal layout) ============ */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #e2e8f0;
  z-index: 10;
  min-height: 96rpx;
}
.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1 1 auto;
  min-width: 0; /* 关键: 防止 flex item 被超长中文撑爆 */
  overflow: hidden;
}
.header-text {
  flex: 1 1 auto;
  min-width: 0;
  overflow: hidden;
}
.header-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: keep-all;
}
.header-sub {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.header-arrow {
  font-size: 20rpx;
  color: #94a3b8;
  margin-left: 8rpx;
  flex-shrink: 0;
}
.header-right {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0; /* 关键: 按钮不被压 */
}
.header-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  background: #f1f5f9;
  color: #475569;
  border: none;
  border-radius: 9999rpx;
  margin: 0;
  line-height: 1.6;
  flex-shrink: 0;
}
.header-btn::after { border: none; }

.sage-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: bold;
  font-size: 20rpx;
  font-family: ui-monospace, monospace;
  flex-shrink: 0;
}

.sage-picker {
  background: #fff;
  border-bottom: 1rpx solid #e2e8f0;
  padding: 12rpx 16rpx;
  z-index: 9;
}
.sage-pick-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
}
.sage-pick-item.active { background: #f1f5f9; }

.messages {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #eff6ff 100%);
}

.empty {
  text-align: center;
  padding: 80rpx 32rpx 60rpx;
}
.empty-avatar-wrap {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto;
}
.empty-avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: 700;
  font-size: 38rpx;
  font-family: ui-monospace, monospace;
  box-shadow: 0 12rpx 36rpx rgba(0,0,0,0.14), 0 4rpx 12rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 1;
}
.empty-avatar-pulse {
  position: absolute;
  inset: 0;
  width: 144rpx;
  height: 144rpx;
  border-radius: 36rpx;
  opacity: 0.32;
  animation: empty-pulse 2.4s ease-out infinite;
}
@keyframes empty-pulse {
  0%   { transform: scale(1); opacity: 0.36; }
  70%  { transform: scale(1.45); opacity: 0; }
  100% { transform: scale(1.45); opacity: 0; }
}
.empty-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
  margin-top: 36rpx;
  letter-spacing: 1rpx;
}
.empty-title-name { font-weight: 700; }
.empty-subtitle {
  font-size: 26rpx;
  color: #475569;
  margin-top: 14rpx;
}
.empty-meta {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 10rpx;
}
.empty-meta-num { color: #1e293b; font-weight: 600; }

/* === sage 横排选择器 === */
.sage-row-label, .starters-label {
  margin-top: 56rpx;
  font-size: 22rpx;
  color: #94a3b8;
  text-align: center;
  letter-spacing: 6rpx;
}
.starters-label { margin-top: 40rpx; }
.sage-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}
.sage-row-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 16rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  background: #fff;
  min-width: 140rpx;
  transition: all 0.2s;
}
.sage-row-card-hover { transform: translateY(2rpx); }
.sage-row-card.active {
  border-color: #3b82f6;
  background: #eff6ff;
  box-shadow: 0 8rpx 24rpx rgba(59,130,246,0.18);
  transform: translateY(-2rpx);
}
.sage-row-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: 700;
  font-size: 22rpx;
  font-family: ui-monospace, monospace;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.08);
}
.sage-row-name {
  font-size: 24rpx;
  color: #475569;
  margin-top: 12rpx;
  font-weight: 500;
}
.sage-row-card.active .sage-row-name { color: #1d4ed8; font-weight: 600; }
.sage-row-check {
  position: absolute;
  top: 8rpx;
  right: 10rpx;
  font-size: 18rpx;
  color: #3b82f6;
  font-weight: 700;
}

.starters {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14rpx;
  margin-top: 20rpx;
  padding: 0 32rpx;
}
.starter-chip {
  padding: 14rpx 28rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 9999rpx;
  font-size: 26rpx;
  color: #475569;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}
.starter-chip-hover {
  background: #eff6ff;
  border-color: #93c5fd;
  color: #1d4ed8;
  transform: translateY(-2rpx);
}

.msg-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.msg-user { flex-direction: row-reverse; }

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: bold;
  font-size: 22rpx;
  flex-shrink: 0;
}
.avatar-user { background: #0f172a; }

.msg-bubble {
  max-width: 78%;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,.05);
}
.bubble-user {
  background: #0f172a;
  color: #fff;
}
.bubble-sage {
  background: #fff;
  border: 1rpx solid #e2e8f0;
  color: #1e293b;
}

/* v60.1: Analyst 内心分析卡（violet 渐变） */
.analyst-card {
  margin-bottom: 16rpx;
}
.analyst-summary {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  background: #f5f3ff;
  color: #6d28d9;
  font-size: 22rpx;
  line-height: 1.4;
}
.analyst-summary-hover { background: #ede9fe; }
.analyst-emoji { font-size: 22rpx; }
.analyst-title { font-weight: 500; }
.analyst-spin {
  font-size: 20rpx;
  color: #8b5cf6;
  animation: spin 1.2s linear infinite;
  display: inline-block;
}
.analyst-check {
  font-size: 18rpx;
  color: #059669;
  font-weight: bold;
}
.analyst-arrow {
  font-size: 22rpx;
  color: #a78bfa;
  margin-left: 4rpx;
  transition: transform 0.2s;
}
.analyst-arrow.open { transform: rotate(180deg); }
.analyst-body {
  margin-top: 12rpx;
  padding: 18rpx 22rpx;
  background: linear-gradient(135deg, #faf5ff 0%, #ede9fe 100%);
  border-left: 4rpx solid #a78bfa;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #5b21b6;
  line-height: 1.65;
  white-space: pre-wrap;
}

/* v58: tool calls 折叠 pill */
.tools-card {
  margin-bottom: 16rpx;
}
.tools-summary {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 22rpx;
  line-height: 1.4;
}
.tools-summary-hover { background: #e2e8f0; }
.tools-emoji { font-size: 22rpx; }
.tools-title { font-weight: 500; }
.tools-check {
  font-size: 18rpx;
  color: #059669;
  font-weight: bold;
}
.tools-spin {
  font-size: 20rpx;
  color: #f59e0b;
  animation: spin 1.2s linear infinite;
  display: inline-block;
}
.tools-arrow {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: 4rpx;
  transition: transform 0.2s;
}
.tools-arrow.open { transform: rotate(180deg); }
.tools-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.tool-pill {
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  font-size: 22rpx;
}
.tool-pill-head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #334155;
  flex-wrap: wrap;
}
.tool-pill-icon { font-size: 22rpx; }
.tool-pill-label { color: #1e293b; font-weight: 500; }
.tool-pill-args { color: #64748b; font-size: 20rpx; }
.tool-pill-check {
  margin-left: auto;
  font-size: 18rpx;
  color: #059669;
  font-weight: bold;
}
.tool-pill-spin {
  margin-left: auto;
  font-size: 20rpx;
  color: #f59e0b;
  animation: spin 1.2s linear infinite;
  display: inline-block;
}
.tool-pill-result {
  margin-top: 8rpx;
  margin-left: 30rpx;
  padding: 10rpx 14rpx;
  background: #f1f5f9;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #475569;
  line-height: 1.6;
  max-height: 240rpx;
  overflow: hidden;
  white-space: pre-wrap;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

.loading-text { color: #94a3b8; font-size: 26rpx; }
.msg-content { word-wrap: break-word; word-break: break-word; }

/* v60.4-mp.3: markdown render */
.md-text { color: inherit; }
.md-bold { font-weight: 700; color: inherit; }
.md-italic { font-style: italic; color: inherit; }
/* v60.5-mp.1: bold/italic 嵌套 inline 渲染 wrapper（保持行内 + 行为继承） */
.md-inline-wrap { display: inline; }
.md-inline-code {
  font-family: 'SF Mono', Consolas, ui-monospace, monospace;
  background: rgba(15,23,42,0.06);
  padding: 0 8rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #be185d;
}
.bubble-user .md-inline-code { background: rgba(255,255,255,0.18); color: #fef3c7; }
.md-h { font-weight: 700; color: inherit; line-height: 1.4; }
.md-h1 { font-size: 36rpx; margin: 14rpx 0 8rpx; }
.md-h2 { font-size: 32rpx; margin: 12rpx 0 8rpx; }
.md-h3 { font-size: 30rpx; margin: 10rpx 0 6rpx; }
.md-h4, .md-h5, .md-h6 { font-size: 28rpx; margin: 8rpx 0 6rpx; }
.md-p {
  font-size: 28rpx;
  line-height: 1.7;
  margin: 6rpx 0;
  color: inherit;
}
.md-p + .md-p { margin-top: 10rpx; }
.md-ul, .md-ol {
  margin: 8rpx 0 8rpx 8rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.md-li {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
  line-height: 1.7;
}
.md-bullet { color: #3b82f6; font-weight: 700; line-height: 1.7; flex-shrink: 0; }
.bubble-user .md-bullet { color: #93c5fd; }
.md-num {
  color: #3b82f6;
  font-weight: 600;
  min-width: 36rpx;
  line-height: 1.7;
  flex-shrink: 0;
  font-family: ui-monospace, monospace;
}
.bubble-user .md-num { color: #93c5fd; }
.md-li-body { flex: 1; min-width: 0; }
.md-quote {
  border-left: 6rpx solid #cbd5e1;
  padding: 8rpx 18rpx;
  color: #64748b;
  font-style: italic;
  margin: 12rpx 0;
  background: rgba(148,163,184,0.08);
  border-radius: 0 8rpx 8rpx 0;
}
.bubble-user .md-quote { color: #e2e8f0; border-color: #94a3b8; background: rgba(255,255,255,0.1); }
.md-code-block {
  font-family: 'SF Mono', Consolas, ui-monospace, monospace;
  background: #0f172a;
  color: #e2e8f0;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  margin: 10rpx 0;
  white-space: pre-wrap;
  word-break: break-all;
  max-height: 600rpx;
  overflow: hidden;
}
.md-hr {
  height: 2rpx;
  background: #e2e8f0;
  margin: 18rpx 0;
}
.bubble-user .md-hr { background: rgba(255,255,255,0.2); }

/* v60.4-mp: error state + retry */
.error-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.retry-btn {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 20rpx;
  background: #fef2f2;
  border: 1rpx solid #fecaca;
  color: #b91c1c;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.retry-btn-hover { background: #fee2e2; border-color: #fca5a5; }

.followups {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}
.followup-chip {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  color: #1d4ed8;
  padding: 8rpx 18rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
}

.quotes {
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e2e8f0;
}
.quotes-label {
  font-size: 20rpx;
  color: #94a3b8;
  letter-spacing: 1rpx;
  margin-bottom: 12rpx;
}
.quote-item {
  background: #f0f9ff;
  border: 1rpx solid #bae6fd;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  transition: background 0.4s ease, box-shadow 0.4s ease;
}
.quote-flash {
  background: #fef3c7;
  border-color: #fbbf24;
  box-shadow: 0 0 0 4rpx rgba(251,191,36,0.25);
}
.quote-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 6rpx;
}
.quote-num {
  font-weight: 700;
  color: #0c4a6e;
  background: #bae6fd;
  border-radius: 9999rpx;
  padding: 0 12rpx;
  height: 32rpx;
  line-height: 32rpx;
  font-size: 20rpx;
  font-family: ui-monospace, monospace;
}
.quote-meta {
  color: #0369a1;
  font-size: 20rpx;
  font-family: ui-monospace, monospace;
}
.quote-text {
  color: #1e293b;
  line-height: 1.6;
}

/* v57.2: relevance + recency badges */
.badge {
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 9999rpx;
  line-height: 1.5;
  font-weight: 500;
}
.badge-rel-strong { background: #d1fae5; color: #065f46; }
.badge-rel-mid    { background: #e0f2fe; color: #075985; }
.badge-rel-weak   { background: #f1f5f9; color: #475569; }
.badge-rec-hot { background: #fef3c7; color: #92400e; }
.badge-rec-mid { background: #ede9fe; color: #5b21b6; }
.badge-rec-old { background: #f1f5f9; color: #64748b; }

/* v54: inline citation chip */
.cite-chip {
  display: inline-block;
  background: #dbeafe;
  color: #1d4ed8;
  padding: 0 12rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-family: ui-monospace, monospace;
  margin: 0 4rpx;
  line-height: 1.4;
  font-weight: 500;
}
.cite-chip:active { background: #93c5fd; }
.msg-text { color: inherit; }

/* v60.5-mp.1: scroll-to-bottom 浮按钮 */
.scroll-bottom-btn {
  position: fixed;
  right: 32rpx;
  bottom: 180rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 9999rpx;
  background: #fff;
  border: 1rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #475569;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.12), 0 2rpx 6rpx rgba(0,0,0,0.06);
  z-index: 8;
  transition: all 0.18s;
}
.scroll-bottom-btn-hover {
  transform: scale(0.92);
  background: #f8fafc;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx 32rpx;
  background: #fff;
  border-top: 1rpx solid #e2e8f0;
}
.input-wrap {
  flex: 1;
  position: relative;
  display: flex;
  align-items: flex-end;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 32rpx;  /* v60.5: 多行后用稍小圆角 */
  padding: 8rpx 22rpx 8rpx 28rpx;
  transition: all 0.2s;
  min-height: 76rpx;
  max-height: 320rpx;
}
.input-wrap:focus-within {
  background: #fff;
  border-color: #93c5fd;
  box-shadow: 0 0 0 6rpx rgba(59,130,246,0.1);
}
.input {
  flex: 1;
  padding: 14rpx 0;
  font-size: 28rpx;
  color: #0f172a;
  background: transparent;
  line-height: 1.5;
  /* textarea-specific */
  min-height: 44rpx;
  max-height: 240rpx;
  width: auto;
}
.input-ph { color: #94a3b8; }
.input-counter {
  font-size: 20rpx;
  color: #cbd5e1;
  font-family: ui-monospace, monospace;
  margin-left: 10rpx;
  flex-shrink: 0;
}
.input-counter-warn { color: #f59e0b; font-weight: 600; }
.send-btn {
  border-radius: 9999rpx;
  padding: 0 36rpx;
  height: 76rpx;
  line-height: 76rpx;
  color: white;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  margin: 0;
  box-shadow: 0 6rpx 20rpx rgba(59,130,246,0.25);
  transition: all 0.2s;
}
.send-btn::after { border: none; }
.send-btn-hover { transform: scale(0.96); box-shadow: 0 2rpx 6rpx rgba(59,130,246,0.2); }
.send-btn[disabled] { opacity: 0.35; box-shadow: none; }
.send-btn-loading { opacity: 0.85; }
