/* 全局样式 */
page {
  background: #f8fafc;
  color: #0f172a;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 通用 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.gap-1 { gap: 8rpx; }
.gap-2 { gap: 16rpx; }
.gap-3 { gap: 24rpx; }
.flex-1 { flex: 1; }
.text-xs { font-size: 22rpx; }
.text-sm { font-size: 26rpx; }
.text-md { font-size: 30rpx; }
.text-lg { font-size: 34rpx; }
.text-slate-400 { color: #94a3b8; }
.text-slate-500 { color: #64748b; }
.text-slate-600 { color: #475569; }
.text-slate-700 { color: #334155; }
.text-slate-900 { color: #0f172a; }
.text-white { color: #fff; }
.text-blue-600 { color: #2563eb; }
.text-amber-700 { color: #b45309; }
.bg-white { background: #fff; }
.bg-slate-50 { background: #f8fafc; }
.bg-slate-100 { background: #f1f5f9; }
.bg-amber-50 { background: #fffbeb; }
.bg-blue-50 { background: #eff6ff; }
.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }
.font-mono { font-family: ui-monospace, monospace; }
.rounded { border-radius: 8rpx; }
.rounded-md { border-radius: 12rpx; }
.rounded-lg { border-radius: 16rpx; }
.rounded-xl { border-radius: 24rpx; }
.rounded-full { border-radius: 9999rpx; }
.border { border: 1rpx solid #e2e8f0; }
.border-amber { border-color: #fbbf24; }
.border-blue { border-color: #3b82f6; }
.shadow { box-shadow: 0 1rpx 3rpx rgba(0,0,0,.08); }
.shadow-md { box-shadow: 0 4rpx 12rpx rgba(0,0,0,.1); }
